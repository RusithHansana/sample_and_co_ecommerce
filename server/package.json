{
  "name": "server",
  "version": "1.0.0",
  "description": "sample & co. ecommerce",
  "license": "ISC",
  "author": "",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "db:migrate": "dotenv -e ../.env.development -- prisma migrate dev",
    "db:push": "dotenv -e ../.env.development -- prisma db push",
    "db:generate": "dotenv -e ../.env.development -- prisma generate",
    "db:seed": "dotenv -e ../.env.development -- prisma db seed",
    "db:studio": "dotenv -e ../.env.development -- prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@prisma/engines@7.8.0": true,
    "prisma@7.8.0": true
  }
}